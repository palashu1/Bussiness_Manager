@model Bussiness_Manager.Models.Customer;
@{
    ViewData["Title"] = "addCustomer";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}


<div class="container-sm mt-3">
    <div class="row justify-content-center shadow-lg weight" style="background-color:white; border-radius:1rem">
        <div class="col-md-5">
            <h1 class="text-center" style="font-weight:bold">Add Customer</h1>
            <form asp-action="addCustomer" method="post" class="small-text mt-3">

                <div class="form-group mb-3">
                    <input asp-for="name" class="form-control Re" type="text" placeholder=" " />
                    <label asp-for="name" style="font-weight:400">Customer Name</label>
                    <span asp-validation-for="name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <input asp-for="address" class="form-control Re" type="text" placeholder=" " />
                    <label asp-for="address">Address</label>
                    <span asp-validation-for="address" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <input asp-for="mobileNo" class="form-control Re" type="number" placeholder=" " />
                    <label asp-for="mobileNo">Mobile no</label>
                    <span asp-validation-for="mobileNo" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary form-group mb-3 w-100 weight">Add+</button>
                
            </form>
        </div>

        <div class="col-md-7 widget">
            <div class=" h-100 d-flex justify-content-center align-items-center">
                <i class="fa-solid fa-shapes fa-2xl"></i>
            </div>
        </div>
    </div>
</div>




@section Scripts {


    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        @if (TempData["ShowAlert"] != null)
        {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    Swal.fire({
                        title: '@ViewBag.title',
                        text: '@ViewBag.message',
                        icon: '@ViewBag.icon',
                        timer: 5000,
                        timerProgressBar: true,
                        didClose: () => {
                            window.location.href = '@Url.Action("Login", "Home")';
                        }
                    });
                });
            </script>
        }

        @if (TempData["ShowAlert1"] != null)
        {

            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    Swal.fire({
                        title: '@ViewBag.title',
                        text: '@ViewBag.message',
                        icon: '@ViewBag.icon',
                        timer: 5000,
                        timerProgressBar: true,
                        didClose: () => {
                            // Redirect after the alert closes
                            window.location.href = '@Url.Action("getShops", "Home")';
                        }
                    });
                });
            </script>
        }

        @if (TempData["ShowAlert2"] != null)
        {

            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    Swal.fire({
                        title: '@ViewBag.title',
                        text: '@ViewBag.message',
                        icon: '@ViewBag.icon',
                        timer: 5000,
                        timerProgressBar: true,
                        didClose: () => {
                            // Redirect after the alert closes
                            window.location.href = '@Url.Action("AddShop", "Home")';
                        }
                    });
                });
            </script>
        }

    }
}