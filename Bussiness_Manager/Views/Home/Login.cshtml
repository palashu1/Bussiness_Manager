<div class="login-form">
    <div class="company_logo text-center">
        <a href="/">
           <img src="/images/download.jfif">
        </a>
    </div>
    <div class="login_heading">
        <h2>Log in</h2>
    </div>
    <div class="login_input">
        <form asp-action="Login" method="post" class="small-text mt-3">
            <div class="form-group">
                <label asp-for="phone">
                    <i class="fa fa-mobile"></i>
                    Mobile No
                </label>
                <div class="custom_input position-relative">
                    <input asp-for="phone" type="number" min="0" class="form-control" name="phone" placeholder="Enter Mobile Number">
                    <span class="number_input">+91</span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="password">
                    <i class="fa fa-lock"></i>
                    Password
                </label>
                <input asp-for="password" type="password" class="form-control" name="password" placeholder="Enter Password">

            </div>
            <div class="form-group">
                <button type="submit" class="btn w-100">Log in</button>
            </div>
        </form>
        <div class="form-group d-flex justify-content-between forgot_password mb-0">
            <a href="/">Forgot password ?</a>
        </div>
    </div>
    <div class="not_register text-center mt-3">
        <p>
            Not registered ?
            <a href="@Url.Action("Registration", "Home")">Sign up</a>
        </p>
    </div>
</div>


@section Scripts {
   

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        @if (TempData["ShowAlert"] != null)
        {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    Swal.fire({
                        title: '@ViewBag.title',
                        text: '@ViewBag.message',
                        icon: '@ViewBag.icon',
                        timer: 3000, 
                        timerProgressBar: true,
                        didClose: () => {
                            window.location.href = '@Url.Action("Login", "Home")';
                        }
                    });
                });
            </script>
        }

        @if (TempData["ShowAlert1"] != null)
        {
            
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    Swal.fire({
                        title: '@ViewBag.title',
                        text: '@ViewBag.message',
                        icon: '@ViewBag.icon',
                        timer: 3000,
                        timerProgressBar: true,
                        didClose: () => {
                            // Redirect after the alert closes
                            window.location.href = '@Url.Action("getShops", "Home")';
                        }
                    });
                });
            </script>
        }

        @if (TempData["ShowAlert2"] != null)
        {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    Swal.fire({
                        title: '@ViewBag.title',
                        text: '@ViewBag.message',
                        icon: '@ViewBag.icon',
                        timer: 3000,
                        timerProgressBar: true,
                        didClose: () => {
                            // Redirect after the alert closes
                            window.location.href = '@Url.Action("AddShop", "Home")';
                        }
                    });
                });
            </script>
        }
       
    }
}











