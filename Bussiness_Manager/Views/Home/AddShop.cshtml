@model Bussiness_Manager.Models.ShopDetail;
@{
    ViewData["Title"] = "AddShop";
}

<h1 class="text-center" style="font-weight:bold">Add Shop</h1>



<div class="container-sm mt-3">
    <div class="row justify-content-center shadow-lg weight" style="background-color:white">
        <div class="col-md-5">
            <form asp-action="AddShop" method="post" class="small-text">

                <div hidden class="form-group mb-3 g1 form-group">
                    <input asp-for="memberId" placeholder=" " class="form-control As" value="@Model.memberId"/>
                    <label asp-for="memberId">Shop name</label>
                    <span asp-validation-for="memberId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3 g1 form-group">
                    <input asp-for="shopName" placeholder=" " class="form-control As" />
                    <label asp-for="shopName">Shop name</label>
                    <span asp-validation-for="shopName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <input asp-for="shopDescription" placeholder=" " class="form-control As" />
                    <label asp-for="shopDescription">Description</label>
                    <span asp-validation-for="shopDescription" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <input asp-for="bussinessType" class="form-control As" placeholder=" "  />
                    <label asp-for="bussinessType">Bussiness Type</label>
                    <span asp-validation-for="bussinessType" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <input asp-for="shopAddress" class="form-control As" placeholder=" " />
                    <label asp-for="shopAddress">Address</label>
                    <span asp-validation-for="shopAddress" class="text-danger"></span>
                </div>
                
                    <button type="submit" class="btn btn-primary form-group mb-3 w-100 weight" > Add+</button>
                
            </form>
        </div>

        <div class="col-md-7 widget">
            <div class=" h-100 d-flex justify-content-center align-items-center">
                <i class="fa-solid fa-shapes fa-2xl"></i>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        <script>
            window.onload = function () {
                var button = document.getElementById("confirmationButtonForAddShop");
                if (button.getAttribute("data-has-message") === "True") {
                    displayAlert();
                }
            };

            function displayAlert() {
                Swal.fire('Done', 'Successfully Added', 'success')
            }
        </script>
    }
}

